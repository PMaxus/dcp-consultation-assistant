# Names of the secrets to configure. No values here.
# In the self-hosted n8n setup these live in n8n's encrypted credential store,
# separated from the workflow logic. This file is only a map of what is needed.

# Telegram
TELEGRAM_BOT_TOKEN=

# LLM
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Google Sheets (service catalog & pricing rules)
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
